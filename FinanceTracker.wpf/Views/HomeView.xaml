<UserControl x:Class="FinanceTracker.wpf.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FinanceTracker.wpf.ViewModels"
             xmlns:conv="clr-namespace:FinanceTracker.wpf.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             d:DesignHeight="400" d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Тінь навколо блоку -->
        <DropShadowEffect x:Key="DropShadowEffect"
                          ShadowDepth="2"
                          BlurRadius="8"
                          Opacity="0.2" />

        <!-- Конвертер кольору для балансу -->
        <conv:BalanceToBrushConverter x:Key="BalanceToBrushConverter"/>
    </UserControl.Resources>

    <Grid Margin="5">
        <Border Background="White"
                CornerRadius="12"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок + період -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Finance Dashboard"
                               FontWeight="Bold"
                               FontSize="22"
                               Foreground="#111827"/>

                    <TextBlock Text="{Binding CurrentPeriodText}"
                               Foreground="#6B7280"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Overall Balance -->
                <Border Grid.Row="1"
                        Background="#F9FAFB"
                        CornerRadius="10"
                        Padding="14,10"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Overall Balance"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="#374151"/>

                            <TextBlock Text="{Binding TotalBalance, StringFormat='{}{0:C}'}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{Binding TotalBalance, Converter={StaticResource BalanceToBrushConverter}}"/>
                        </StackPanel>

                        <Grid Grid.Column="1" Margin="20,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Дохід -->
                            <StackPanel Grid.Row="0" HorizontalAlignment="Right">
                                <TextBlock Text="Income"
                                           FontWeight="Medium"
                                           FontSize="13"
                                           Foreground="#1F2937"/>

                                <TextBlock Text="{Binding TotalIncome, StringFormat='{}{0:C}'}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#10B981"/>
                            </StackPanel>

                            <!-- Витрати -->
                            <StackPanel Grid.Row="1" HorizontalAlignment="Right">
                                <TextBlock Text="Expenses"
                                           FontWeight="Medium"
                                           FontSize="13"
                                           Foreground="#1F2937"/>

                                <TextBlock Text="{Binding TotalExpenses, StringFormat='{}{0:C}'}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#EF4444"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Роздільна лінія -->
                <Border Grid.Row="2"
                        Height="1"
                        Background="#E5E7EB"
                        Margin="0,0,0,16"/>

                <!-- Net + Savings -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Net -->
                    <Border Grid.Column="0"
                            Background="#F9FAFB"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Net"
                                       FontWeight="Medium"
                                       FontSize="13"
                                       Foreground="#374151"/>

                            <TextBlock Text="{Binding TotalBalance, StringFormat='{}{0:C}'}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{Binding TotalBalance, Converter={StaticResource BalanceToBrushConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Savings -->
                    <Border Grid.Column="1"
                            Background="#F9FAFB"
                            CornerRadius="8"
                            Padding="10"
                            Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Savings"
                                       FontWeight="Medium"
                                       FontSize="13"
                                       Foreground="#374151"/>

                            <TextBlock Text="{Binding TotalIncome, StringFormat='{}{0:C}'}"
                                       ToolTip="Поки відображає дохід. Converter буде додано далі."
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#3B82F6"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
