<UserControl x:Class="FinanceTracker.wpf.Views.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FinanceTracker.wpf.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="Category Summary" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>

                <!-- Таблиця топ витрат -->
                <DataGrid ItemsSource="{Binding TopExpenseCategories}" 
                          AutoGenerateColumns="False"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          CanUserResizeColumns="False"
                          Margin="0,0,0,20">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" 
                                          Binding="{Binding Name}" 
                                          Width="*"/>
                        <DataGridTextColumn Header="Amount" 
                                          Binding="{Binding Amount, StringFormat={}{0:C}}" 
                                          Width="120"/>
                        <DataGridTextColumn Header="% of total" 
                                          Binding="{Binding Percentage, StringFormat={}{0:F1}%}" 
                                          Width="100"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Amount}" Value="0">
                                    <Setter Property="Foreground" Value="#6B7280"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <TextBlock Text="{Binding CurrentPeriodText}" 
                           FontSize="14" 
                           Foreground="#6B7280" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
