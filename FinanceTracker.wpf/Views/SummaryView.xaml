<UserControl x:Class="FinanceTracker.wpf.Views.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FinanceTracker.wpf.ViewModels"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="12" Padding="20">

            <StackPanel>

                <!-- Заголовок -->
                <TextBlock Text="Category Summary"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Найбільша категорія витрат -->
                <Border Background="#FEF3C7"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,10">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Biggest expense:"
                                   FontWeight="SemiBold"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="{Binding TopExpenseCategoryName}"
                                   FontWeight="Bold"/>

                        <TextBlock Text=" - "
                                   Margin="5,0"/>

                        <TextBlock Text="{Binding TopExpenseCategoryAmount, StringFormat={}{0:C}}"/>

                    </StackPanel>

                </Border>

                <!-- Кількість транзакцій -->
                <TextBlock Text="{Binding TransactionCount, StringFormat=Transactions: {0}}"
                           FontSize="14"
                           Foreground="#6B7280"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <!-- Топ витрати -->
                <TextBlock Text="Top Expenses"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>

                <DataGrid ItemsSource="{Binding TopExpenseCategories}"
                          AutoGenerateColumns="False"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          CanUserResizeColumns="False"
                          Margin="0,0,0,20">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Name}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Amount"
                                            Binding="{Binding Amount, StringFormat={}{0:C}}"
                                            Width="120"/>

                        <DataGridTextColumn Header="%"
                                            Binding="{Binding Percentage, StringFormat={}{0:F1}%}"
                                            Width="60"/>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- Період -->
                <TextBlock Text="{Binding CurrentPeriodText, StringFormat=Period: {0}}"
                           FontSize="14"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Expenses Distribution"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <lvc:PieChart Series="{Binding ExpenseSeries}"
                           Height="250"
                           LegendLocation="Right"
                           Margin="0,0,0,20"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>