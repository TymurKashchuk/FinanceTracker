<Window x:Class="FinanceTracker.wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FinanceTracker.wpf.ViewModels"
        xmlns:views="clr-namespace:FinanceTracker.wpf.Views"
        xmlns:conv="clr-namespace:FinanceTracker.wpf.Converters"
        mc:Ignorable="d"
        Title="Finance Tracker"
        Height="660"
        Width="1200"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Верхня панель-->
        <Border Background="White"
                CornerRadius="8"
                Padding="15"
                DockPanel.Dock="Top">
            <StackPanel>

                <WrapPanel Margin="0,0,0,10">

                    <TextBox Width="200"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBox Width="100"
                             Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>

                    <ComboBox Width="140"
                              ItemsSource="{Binding Accounts}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedAccount}"/>

                    <ComboBox Width="140"
                              ItemsSource="{Binding TransactionTypes}"
                              SelectedItem="{Binding TransactionType}"
                              Margin="0,0,10,0"/>

                    <ComboBox Width="140"
                              ItemsSource="{Binding Categories}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedCategory}"
                              Visibility="{Binding IsExpenseSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- ПЕРІОДИ -->
                    <ComboBox Width="110"
                              ItemsSource="{Binding PeriodTypes}"
                              SelectedItem="{Binding SelectedPeriod}"/>

                    <Button Content="Today"
                            Width="65"
                            Style="{StaticResource PeriodButtonStyle}"
                            Command="{Binding SetPeriodTodayCommand}"/>
                    <Button Content="Week"
                            Width="65"
                            Style="{StaticResource PeriodButtonStyle}"
                            Command="{Binding SetPeriodWeekCommand}"/>
                    <Button Content="Month"
                            Width="65"
                            Style="{StaticResource PeriodButtonStyle}"
                            Command="{Binding SetPeriodMonthCommand}"/>

                    <!-- ЛЕЙБЛ ПОТОЧНОГО ПЕРІОДУ -->
                    <TextBlock Text="{Binding CurrentPeriodText}"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               Margin="5,0"
                               FontSize="12"/>

                </WrapPanel>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Add"
                            Width="100"
                            Command="{Binding AddCommand}"/>
                    
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Вкладки -->
        <TabControl DockPanel.Dock="Top"
                    Margin="0,15,0,0"
                    Background="Transparent"
                    BorderBrush="Transparent">
            <TabItem Header="Home">
                <views:HomeView/>
            </TabItem>

            <TabItem Header="Transactions">
                <views:TransactionsView/>
            </TabItem>

            <TabItem Header="Summary">
                <views:SummaryView DataContext="{Binding}"/>
            </TabItem>
        </TabControl>

    </DockPanel>
</Window>
